{
  "name": "pharmacy-mvp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/mobile",
    "apps/api"
  ],
  "scripts": {
    "start": "npm run mobile:start",
    "mobile:start": "npm --workspace @pharmacy/mobile run start",
    "mobile:android": "npm --workspace @pharmacy/mobile run android",
    "mobile:ios": "npm --workspace @pharmacy/mobile run ios",
    "mobile:web": "npm --workspace @pharmacy/mobile run web",
    "mobile:lint": "npm --workspace @pharmacy/mobile run lint",
    "mobile:typecheck": "npm --workspace @pharmacy/mobile run typecheck",
    "api:dev": "npm --workspace @pharmacy/api run dev",
    "api:build": "npm --workspace @pharmacy/api run build",
    "api:typecheck": "npm --workspace @pharmacy/api run typecheck",
    "api:db:push": "npm --workspace @pharmacy/api run db:push",
    "api:db:seed": "npm --workspace @pharmacy/api run db:seed"
  }
}
