generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String?
  imageUrl      String?
  sortOrder     Int           @default(0)
  products      Product[]
  subcategories Subcategory[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Subcategory {
  id          String    @id @default(cuid())
  categoryId  String
  parentId    String?
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  category    Category  @relation(fields: [categoryId], references: [id])
  parent      Subcategory?  @relation("SubcategoryChildren", fields: [parentId], references: [id])
  children    Subcategory[] @relation("SubcategoryChildren")
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Brand {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  logoUrl    String?
  sortOrder  Int       @default(0)
  isFeatured Boolean   @default(false)
  products   Product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Customer {
  id           String   @id @default(cuid())
  fullName     String
  phone        String   @unique
  passwordHash String
  sessionToken String?  @unique
  addresses    Address[]
  insuranceProfiles InsuranceProfile[]
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model InsuranceProfile {
  id                       String          @id @default(cuid())
  customerId               String
  cardholderName           String
  providerName             String
  memberNumber             String
  frontImageUrl            String?
  backImageUrl             String?
  nationalIdFrontImageUrl  String?
  nationalIdBackImageUrl   String?
  status                   InsuranceStatus @default(PENDING_REVIEW)
  useByDefault             Boolean         @default(false)
  customer                 Customer        @relation(fields: [customerId], references: [id])
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
}

model InsuranceProvider {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id            String      @id @default(cuid())
  categoryId    String
  subcategoryId String?
  brandId       String?
  name          String
  slug          String      @unique
  description   String
  packageSize   String
  pricePiasters Int
  imageUrl      String?
  inStock       Boolean     @default(true)
  isPopular     Boolean     @default(false)
  category      Category    @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])
  brand         Brand?      @relation(fields: [brandId], references: [id])
  units         ProductUnit[]
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ProductUnit {
  id            String      @id @default(cuid())
  productId     String
  label         String
  pricePiasters Int
  isDefault     Boolean     @default(false)
  sortOrder     Int         @default(0)
  product       Product     @relation(fields: [productId], references: [id])
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([productId, label])
}

model Offer {
  id              String   @id @default(cuid())
  title           String
  description     String
  badge           String?
  discountPercent Int?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PrescriptionUpload {
  id           String   @id @default(cuid())
  originalName String
  fileName     String
  mimeType     String
  sizeBytes    Int
  orderId      String?
  order        Order?   @relation(fields: [orderId], references: [id])
  createdAt    DateTime @default(now())
}

model Address {
  id              String   @id @default(cuid())
  customerId      String?
  addressName     String
  fullName        String
  phone           String
  additionalPhone String?
  city            String
  area            String
  street          String
  building        String
  floor           String?
  apartment       String?
  landmark        String?
  isDefault       Boolean  @default(false)
  customer        Customer? @relation(fields: [customerId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String
  phone     String
  hours     String
  latitude  Float?
  longitude Float?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                  String               @id @default(cuid())
  customerId          String?
  type                OrderType            @default(PRODUCT_ORDER)
  customerName        String
  customerPhone       String
  address             String
  fulfillmentMethod   FulfillmentMethod    @default(DELIVERY)
  deliveryDate        String?
  deliveryTimeSlot    String?
  paymentMethod       PaymentMethod        @default(CASH_ON_DELIVERY)
  pricingStatus       PricingStatus        @default(NOT_REQUIRED)
  confirmByCall       Boolean              @default(false)
  deliveryFeePiasters Int                  @default(0)
  notes               String?
  status              OrderStatus          @default(RECEIVED)
  customer            Customer?            @relation(fields: [customerId], references: [id])
  items               OrderItem[]
  prescriptions       PrescriptionUpload[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model OrderItem {
  id            String       @id @default(cuid())
  orderId       String
  productId     String
  productUnitId String?
  unitLabel     String?
  quantity      Int
  pricePiasters Int
  order         Order        @relation(fields: [orderId], references: [id])
  product       Product      @relation(fields: [productId], references: [id])
  productUnit   ProductUnit? @relation(fields: [productUnitId], references: [id])
}

enum OrderStatus {
  PENDING_REVIEW
  RECEIVED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
}

enum OrderType {
  PRODUCT_ORDER
  PRESCRIPTION_REQUEST
}

enum FulfillmentMethod {
  DELIVERY
  PICKUP
}

enum PaymentMethod {
  ONLINE
  CASH_ON_DELIVERY
  CARD_ON_DELIVERY
}

enum PricingStatus {
  NOT_REQUIRED
  PENDING_REVIEW
  PRICED
}

enum InsuranceStatus {
  NOT_VERIFIED
  PENDING_REVIEW
  VERIFIED
}
