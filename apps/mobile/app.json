{
  "expo": {
    "name": "pharmacy-mvp",
    "slug": "pharmacy-mvp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/elkhabiry-app-icon.png",
    "splash": {
      "image": "./assets/images/elkhabiry-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "pharmacymvp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/elkhabiry-android-foreground.png",
        "backgroundImage": "./assets/images/elkhabiry-android-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow pharmacy-mvp to access your photos so you can upload prescriptions.",
          "cameraPermission": "Allow pharmacy-mvp to access your camera so you can photograph prescriptions.",
          "microphonePermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/elkhabiry-splash.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/elkhabiry-splash.png",
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "@react-native-community/datetimepicker",
        {
          "android": {
            "datePicker": {
              "colorAccent": {
                "light": "#00b6bd",
                "dark": "#00b6bd"
              },
              "colorControlActivated": {
                "light": "#00b6bd",
                "dark": "#00b6bd"
              },
              "textColorPrimary": {
                "light": "#111827",
                "dark": "#FFFFFF"
              },
              "textColorSecondary": {
                "light": "#6B7280",
                "dark": "#CFF2F1"
              },
              "windowBackground": {
                "light": "#FFFFFF",
                "dark": "#111827"
              }
            },
            "timePicker": {
              "background": {
                "light": "#FFFFFF",
                "dark": "#111827"
              },
              "headerBackground": {
                "light": "#00b6bd",
                "dark": "#00b6bd"
              },
              "numbersSelectorColor": {
                "light": "#00b6bd",
                "dark": "#00b6bd"
              },
              "numbersTextColor": {
                "light": "#111827",
                "dark": "#FFFFFF"
              }
            }
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
